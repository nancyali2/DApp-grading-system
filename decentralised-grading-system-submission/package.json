    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "chai-bignumber": "^2.0.2",
    "lite-server": "^2.3.0",
    "nodemon": "^1.19.1",
    "truffle": "5.0.2",
    "truffle-contract": "3.0.6",
    "web3": "^1.2.1"
  },
  "repository": {
